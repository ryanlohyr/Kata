# Supabase Postgres connection string. Get it from:
#   Supabase → Project Settings → Database → Connection string → "Transaction" pooler
# The pooler (port 6543) is required for serverless / short-lived connections.
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-X-region.pooler.supabase.com:6543/postgres

# Decodo Web Scraping API — Basic auth credentials
DECODO_USERNAME=your_decodo_user
DECODO_PASSWORD=your_decodo_pass

# Cron endpoint shared secret — protects /api/cron/poll
CRON_SECRET=generate-a-long-random-string
