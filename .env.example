# Supabase — service role key (server-only) and anon key (browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Decodo Web Scraping API — Basic auth credentials
DECODO_USERNAME=your_decodo_user
DECODO_PASSWORD=your_decodo_pass

# Cron endpoint shared secret — protects /api/cron/poll
CRON_SECRET=generate-a-long-random-string
